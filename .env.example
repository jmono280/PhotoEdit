# Base de datos
DATABASE_URL=postgresql+asyncpg://photo_edit:photo_edit_pass@localhost:5433/photo_edit_db

# Seguridad JWT
SECRET_KEY=cambia-esto-por-un-secreto-seguro-de-al-menos-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-image
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_X_TITLE=Photo Edit AI

# Archivos
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# Procesamiento por lote
MAX_IMAGES_PER_BATCH=20
BATCH_CONCURRENCY=3

# App
CORS_ORIGINS=http://localhost:8000
APP_NAME=Photo Edit AI
DEBUG=false
